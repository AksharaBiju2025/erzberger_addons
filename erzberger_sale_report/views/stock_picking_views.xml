<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_inherit_delivery_note" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.delivery.note</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">

            <xpath expr="//button[@name='%(stock.action_report_delivery)d']"
                   position="replace">
                <button
                    name="action_print_delivery_custom"
                    type="object"
                    string="Delivery Note"
                    class="oe_highlight"
                    invisible="state != 'done'"/>
            </xpath>

        </field>
    </record>
</odoo>