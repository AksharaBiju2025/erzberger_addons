<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_order_form_auftragsbestatigung_btn" model="ir.ui.view">
        <field name="name">sale.order.form.auftragsbestatigung.button</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header//button[@name='sale.action_report_saleorder']" position="replace">
                <button
                    string="Print"
                    name="action_print_custom"
                    type="object"
                    data-hotkey="i"/>
            </xpath>
        </field>
    </record>

    

</odoo>
