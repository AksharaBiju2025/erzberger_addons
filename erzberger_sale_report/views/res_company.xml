<odoo>
    <record id="view_company_form_inherit_report_desc" model="ir.ui.view">
        <field name="name">res.company.form.report.description</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>

        <field name="arch" type="xml">
            <xpath expr="//page[@name='branches']" position="after">
                <page string="Report Settings" name="report_settings">
<!--                     <group>-->
<!--                        <field name="use_custom_sale_report"/>-->
<!--                    </group>-->
                    <group>
                        <field name="report_company_description1"/>
                    </group>
                    <group>
                        <field name="report_company_description2"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>