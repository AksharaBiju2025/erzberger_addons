<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="paperformat_sale_order_confirmation" model="report.paperformat">
        <field name="name">Sale Order Confirmation A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">70</field>
        <field name="header_spacing">70</field>
        <field name="margin_bottom">30</field>
        <field name="margin_left">11</field>
        <field name="margin_right">11</field>
        <field name="header_line" eval="False"/>
        <field name="dpi">96</field>
    </record>

    <record id="action_report_auftragsbestatigungs" model="ir.actions.report">
        <field name="name">Sale Order Confirmation</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">erzberger_sale_report.report_auftragsbestatigung_documents</field>
        <field name="report_file">erzberger_sale_report.report_auftragsbestatigung_documents</field>
        <field name="print_report_name">'Auftragsbestaetigung - %s' % (object.name)</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id"
           ref="erzberger_sale_report.paperformat_sale_order_confirmation"/>
    </record>

</odoo>
