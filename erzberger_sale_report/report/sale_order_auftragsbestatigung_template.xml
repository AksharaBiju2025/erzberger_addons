<?xml version="1.0" encoding="utf-8"?>
<odoo>


<template id="report_erz_external_layout"
          inherit_id="web.external_layout_standard"
          primary="True">

<xpath expr="//div[@t-attf-class='header o_company_#{company.id}_layout']"
   position="replace">
    <t t-set="company" t-value="o.company_id.sudo()"/>
    <div t-attf-class="header o_company_#{company.id}_layout"
         style="font-family: Arial, sans-serif; font-size: 11pt; color: #222; padding: 1mm 0 2mm 0; border:1px solid white;">

        <table style="width:100%; border-collapse:collapse; border:1px solid white;">
            <tr>
                <!-- LEFT: Address -->
                <td style="width:25%; vertical-align:bottom; padding-right:4mm; border:1px solid white;">
                    <div style="color:#003399; font-size:11pt; text-decoration:underline; white-space:nowrap; border:1px solid white;">
                        <t t-esc="company.name"/> &#x2022;
                        <t t-esc="company.street"/> &#x2022;
                        D-<t t-esc="company.zip"/> <t t-esc="company.city"/>
                    </div>
                </td>

                <!-- MIDDLE: Description 1 — one item per line -->
                <td style="width:33%; vertical-align:bottom; text-align:left; padding-right:4mm; border:1px solid white;">
                    <div style="
                        color:#4a52a6;
                        font-size:11pt;
                        font-weight:bold;
                        line-height:1.6;
                        white-space:pre-line;
                    "><t t-esc="company.report_company_description1"/></div>
                </td>

                <!-- RIGHT: Logo top + Description 2 below, left-aligned -->
                <td style="width:42%; vertical-align:top; text-align:right; border:1px solid white;">

                    <!-- Logo -->
                    <t t-if="company.logo">
                        <div style="margin-bottom:3mm; text-align:right;">
                            <img t-att-src="image_data_uri(company.logo)"
                                style="height:100px; width:auto;"/>
                        </div>
                    </t>

                    <!-- Description 2 — left-aligned under logo -->
                    <div style="
                        color:#4a52a6;
                        font-size:11pt;
                        font-weight:bold;
                        line-height:1.6;
                        text-align:left;
                        white-space:pre-line;
                    "><t t-esc="company.report_company_description2"/></div>

                </td>
            </tr>
        </table>

    </div>
</xpath>
    <!-- ▶ REPLACE the footer div -->
    <xpath expr="//div[div[@class='o_footer_content d-flex border-top pt-2']]" position="replace">
        <div t-attf-class="footer o_company_#{company.id}_layout"
             style="font-family: Arial, sans-serif; font-size: 9pt; color:#444; padding-top:2mm; border:1px solid white;">

            <hr style="border-top:1px solid #000; margin:0 0 2mm 0;"/>

            <!-- Four-column footer -->
            <table style="width:100%; border-collapse:collapse; border:1px solid white;">
                <tr>
                    <!-- Col 1: company postal address -->
                    <td style="width:26%; vertical-align:top; padding-right:3mm; line-height:1.6; border:1px solid white;">
                        <strong><t t-esc="company.name"/></strong><br/>
                        <t t-esc="company.street"/><br/>
                        D-<t t-esc="company.zip"/> <t t-esc="company.city"/><br/>
                        <t t-esc="company.country_id.name"/>
                    </td>
                    <!-- Col 2: headquarters -->
                    <td style="width:28%; vertical-align:top; padding-right:3mm; line-height:1.6; border:1px solid white;">
                        <strong>Firmensitz / Headquarters</strong><br/>
                        Buntspeicher | Speicherstraße 1<br/>
                        D-08297 Zwönitz / Erzgebirge<br/>
                        Deutschland / Germany<br/>
                        <t t-if="company.phone">Fon: <t t-esc="company.phone"/></t>
                    </td>
                    <!-- Col 3: web / email -->
                    <td style="width:24%; vertical-align:top; padding-right:3mm; line-height:1.6; border:1px solid white;">
                        <strong>Website:</strong><br/>
                        <t t-esc="company.website"/><br/>
                        <strong>E-Mail:</strong><br/>
                        <t t-esc="company.email"/>
                    </td>
                    <!-- Col 4: bank -->
                    <td style="width:22%; vertical-align:top; line-height:1.6; border:1px solid white;">
                        <strong>Bankverbindung</strong><br/>
                        <t t-set="bf" t-value="company.partner_id.bank_ids[:1]"/>
                        <t t-if="bf">
                            <t t-esc="bf.bank_id.name"/><br/>
                            IBAN: <t t-esc="bf.acc_number"/><br/>
                            BIC: <t t-esc="bf.bank_id.bic or ''"/>
                        </t>
                        <t t-else="">
                            Erzgebirgssparkasse<br/>
                            IBAN: DE37 8705 4000 3612 0096 47<br/>
                            BIC: WELADED1STB
                        </t>
                    </td>
                </tr>
            </table>

            <!-- Page number (right-aligned, only in PDF) -->
            <div t-if="report_type == 'pdf'"
                 style="text-align:right; margin-top:1mm; font-size:6pt; color:#888;">
                Seite <span class="page"/> / <span class="topage"/>
            </div>
        </div>
    </xpath>

</template>


<!-- ══════════════════════════════════════════════
     LINK your report to use THIS layout
     ══════════════════════════════════════════════ -->
<template id="report_auftragsbestatigung_documents">
<t t-call="web.html_container">
    <t t-foreach="docs" t-as="doc">

        <!-- ★ KEY LINE: call your custom layout, not the default one -->
        <t t-set="o" t-value="doc"/>
<!--        <t t-set="layout_document_title" t-value="'Auftragsbestätigung'"/>-->
        <t t-call="erzberger_sale_report.report_erz_external_layout">

            <div style="font-family: Arial, sans-serif; font-size: 11pt; color: #222;">
                <br/>
                <br/>
                <br/>
                <br/>
                <br/>
                <br/>
                <br/>
                <br/>
                <style>
                    /* your existing CSS here — same as before */
                    .erz-title { font-size:15pt; font-weight:bold; text-decoration:underline; margin-bottom:1mm; }
                    .erz-ref   { font-size:8.5pt; line-height:1.55; }
                    .meta-lbl  { color:#333; white-space:nowrap; padding-right:3mm; font-size:8.5pt; }
                    .meta-val  { font-weight:bold; text-align:right; font-size:8.5pt; }
                    .otbl { width:100%; border-collapse:collapse; margin-top:1mm; }
                    .otbl thead tr { border-top:1.5px solid #000; border-bottom:1.5px solid #000; }
                    .otbl thead th { font-size:8.5pt; padding:1.5mm 2mm; font-weight:bold; }
                    .otbl tbody td { font-size:8.5pt; padding:2mm; vertical-align:top; border-bottom:0.5px solid #ccc; }
                    .otbl tbody tr:last-child td { border-bottom:1.5px solid #000; }
                    .sub { font-weight:normal; font-size:7pt; }
                    .delivery { font-size:8pt; margin:1.5mm 0; }
                    .tot-inner td { font-size:9pt; padding:0.8mm 2mm; }
                    .tot-grand td { font-weight:bold; border-top:1.5px solid #000; padding-top:1.5mm; }
                    .erz-terms { font-size:8.5pt; margin-top:3mm; line-height:1.55; }
                    .erz-bank  { font-size:9pt; margin-top:4mm; }
                    .erz-bank-center { text-align:center; font-weight:bold; }
                    .tr { text-align:right; } .tl { text-align:left; } .b { font-weight:bold; }
                    p  { margin:0 0 1mm 0; }
                </style>

                <!-- META block -->

                 <!-- Recipient address -->
                <div style="font-size:11pt; line-height:1.65; margin:3mm 0;">
                    <t t-if="doc.partner_id.parent_id">
                        <div><t t-esc="doc.partner_id.parent_id.name"/></div>
                    </t>
                    <div t-field="doc.partner_id"
                         t-options='{"widget":"contact","fields":["name","address"],"no_marker":True}'/>
                </div>
                <table style="width:100%; border-collapse:collapse; margin-top:2mm; border:1px solid white; font-size: 11pt;">
                    <tr>
                        <td style="width:58%; vertical-align:top; padding-right:6mm; border:1px solid white;">
                            <t t-if="doc.state == 'sale'">
                                <div class="erz-title">Auftragsbestätigung</div>
                            </t>
                            <t t-elif="doc.state in ('draft', 'sent')">
                                <div class="erz-title">BESTELLUNG/ORDER</div>
                            </t>

                            <div class="erz-ref" style="font-size: 11pt;">
                                <t t-if="doc.partner_id.name">
                                    (Ihr Auftrag v.
                                    <span t-field="doc.date_order" t-options='{"widget":"date","format":"dd.MM.yyyy"}'/>
                                    p. Email v. <span t-field="doc.partner_id.name"/>)<br/>
                                    Ihre Bestellnr.: <span t-field="doc.name"/><br/>
                                    Ihre Artikelnr.: <br/>
                                </t>
                            </div>
                        </td>
                        <td style="width:42%; vertical-align:top; border:1px solid white; font-size: 11pt;">
                            <table style="border:1px solid white;">
                                <tr style="border:1px solid white;"><td class="meta-lbl" style="border:1px solid white;">AB-Nr.:</td><td class="meta-val b"><span t-field="doc.name"/></td></tr>
                                <tr style="border:1px solid white;">
                                    <td class="meta-lbl" style="border:1px solid white;">Datum:</td>
                                    <td class="meta-val" style="border:1px solid white;">
                                        <span t-field="doc.date_order" t-options='{"widget":"date","format":"dd.MM.yyyy"}'/>
                                    </td>
                                </tr>
                                <t t-if="doc.company_id.company_registry">
                                    <tr style="border:1px solid white;"><td class="meta-lbl" style="border:1px solid white;">St.-Nr.:</td><td class="meta-val"><t t-esc="doc.company_id.company_registry"/></td></tr>
                                </t>
                                <t t-if="doc.company_id.vat">
                                    <tr style="border:1px solid white;"><td class="meta-lbl" style="border:1px solid white;">Ust.-IdNr.:</td><td class="meta-val"><span t-field="doc.company_id.vat"/></td></tr>
                                </t>
                                <t t-if="doc.user_id">
                                    <tr style="border:1px solid white;"><td class="meta-lbl" style="border:1px solid white;">Bearbeiter:</td><td class="meta-val"><span t-field="doc.user_id"/></td></tr>
                                </t>
                            </table>
                        </td>
                    </tr>
                </table>



                <!-- Greeting -->
                <div style="font-size:11pt; margin:2.5mm 0;">
                    Sehr
                    <t t-if="doc.partner_id.parent_id"><t t-esc="doc.partner_id.parent_id.name"/>,</t>
                    <t t-else=""><span t-field="doc.partner_id.name"/>,</t>
                    vielen Dank für Ihren Auftrag, den wir wie folgt bestätigen:
                </div>

                <!-- Order lines -->
                <table class="otbl" style="font-size: 11pt;">
                    <thead>
                        <tr>
                            <th class="tl" style="width:13%; font-size: 11pt;">Menge<br/><span class="sub">kg/Stück</span></th>
                            <th class="tl" style="width:47%; font-size: 11pt;">Bezeichnung</th>
                            <th class="tr" style="width:22%; font-size: 11pt; text-align:center;">Preis/Einheit<br/><span class="sub">per kg/1.000 Stück</span></th>
                            <th class="tr" style="width:18%; font-size: 11pt; text-align:center;">Betrag</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="doc.order_line" t-as="line">
                            <t t-if="line.display_type == 'line_section'">
                                <tr><td colspan="4" class="b" style="font-size:11pt; padding-top:3mm;"><span t-field="line.name"/></td></tr>
                            </t>
                            <t t-elif="line.display_type == 'line_note'">
                                <tr><td colspan="4" style="font-style:italic; font-size:11pt;"><span t-field="line.name"/></td></tr>
                            </t>
                            <t t-else="">
                                <tr>
                                    <td class="tl" style="font-size: 11pt;">
                                        <span t-field="line.product_uom_qty"
                                              t-options='{"widget":"float","decimal_precision":"Product Unit of Measure"}'/>
                                    </td>
                                    <td style="font-size: 11pt;"><span t-field="line.name"/></td>
                                    <td style="font-size: 11pt;" class="tr">
                                        <t t-if="line.price_unit != 0">
                                            <span t-field="line.price_unit" t-options='{"widget":"monetary","display_currency":doc.currency_id}'/>
                                        </t><t t-else="">–</t>
                                    </td>
                                    <td style="font-size: 11pt;" class="tr">
                                        <t t-if="line.price_subtotal != 0">
                                            <span t-field="line.price_subtotal" t-options='{"widget":"monetary","display_currency":doc.currency_id}'/>
                                        </t><t t-else="">–</t>
                                    </td>
                                </tr>
                            </t>
                        </t>
                        <t t-if="doc.state == 'sale'">
                            <tr>
                                <td colspan="4"
                                    style="padding:3mm 2mm; font-size:11pt; line-height:1.5; border-bottom:0.5px solid #ccc;">
                                    Aufgrund der nicht planbaren, sehr dynamischen Preisentwicklung im
                                    Rohstoff-, Energie- und Frachtbereich bestätigen wir unsere
                                    Preisangaben freibleibend. Wir behalten uns vor, unsere Preise in
                                    Rücksprache mit Ihnen anzupassen, sollten die Kosten bis zur
                                    Produktion um mehr als 5% steigen. Die Einhaltung unseres
                                    bestätigten Liefertermins setzt eine reibungslose
                                    Rohstoffversorgung voraus.
                                </td>
                            </tr>
                        </t>
                        <t t-elif="doc.state in ('draft', 'sent')">
                            <tr>
                                <td colspan="4"
                                    style="padding:3mm 2mm; font-size:11pt; line-height:1.5; border-bottom:0.5px solid #ccc;">
                                     Wir vereinbaren 100% Kundenschutz für diesen und alle Folgeaufträge.
                                     Kenntnisse aus und über diesen Auftrag dürfen ohne unsere Zustimmung nicht an Dritte weiter gegeben werden.
                                     Eine Weitervergabe des Auftrages an Dritte ist nur mit unserer Zustimmung zulässig.
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <div style="font-size: 11pt;" class="delivery">
                </div>

                <!-- Totals -->
                <table style="width:100%; border-collapse:collapse; border:1px solid white; font-size: 11pt;">
                    <tr>
                        <td style="width:55%; border:1px solid white;"></td>
                        <td style="width:45%; border:1px solid white;">
                            <table style="width:100%; border-collapse:collapse; border:1px solid white;" class="tot-inner">
                                <t t-set="tax_totals" t-value="doc.tax_totals"/>
                                <t t-foreach="tax_totals['subtotals']" t-as="subtotal">
                                    <tr style="border:1px solid white;">
                                        <td style="text-align:right; border:1px solid white; font-size: 11pt;" class="tot-lbl">Warenwert</td>
                                        <td style="text-align:left; border:1px solid white; font-size: 11pt;" class="tot-val">
                                            <span t-out="subtotal['base_amount_currency']"
                                                  t-options='{"widget":"monetary","display_currency":doc.currency_id}'/>
                                        </td>
                                    </tr>
                                    <t t-foreach="subtotal['tax_groups']" t-as="tax_group">
                                        <tr style="border:1px solid white;">
                                            <td style="text-align:right; border:1px solid white; font-size: 11pt;" class="tot-lbl">zzgl. <span t-out="tax_group['group_name']"/></td>
                                            <td style="text-align:left; border:1px solid white; font-size: 11pt;" class="tot-val">
                                                <span t-out="tax_group['tax_amount_currency']"
                                                      t-options='{"widget":"monetary","display_currency":doc.currency_id}'/>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                                <tr style="border:1px solid white;" class="tot-grand">
                                    <td style="text-align:right; border:1px solid white; font-size: 11pt;" class="tot-lbl b">Gesamtbetrag</td>
                                    <td style="text-align:left; border:1px solid white; font-size: 11pt;" class="tot-val b">
                                        <span t-field="doc.amount_total"
                                              t-options='{"widget":"monetary","display_currency":doc.currency_id}'/>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>

                <!-- Terms -->
                <div class="erz-terms" style="font-size:11pt;">

                    <!-- Quotation -->
                    <t t-if="doc.state in ('draft', 'sent')">

                        <p>Packeinheit: 8,23 kg netto für netto in ERZBERGER-Karton</p>

                        <p>Druckplatten: sind in Ihrem Hause. Qualität und Ausführung wie zuletzt in 2025 geliefert.</p>

                        <p>Auftrag soll ohne "Grüner Punkt" gefertigt werden.</p>

                        <p>
                            Liefertermin:
                            <t t-if="doc.commitment_date">
                                <span t-field="doc.commitment_date"
                                      t-options='{"widget":"date","format":"dd.MM.yyyy"}'/>
                            </t>
                        </p>

                        <p>Verpackung u. Versand: streng neutral mit unserem ERZBERGER-Lieferschein</p>

                        <p>
                            Zahlung:
                            <t t-if="doc.payment_term_id">
                                <span t-field="doc.payment_term_id.name"/>
                            </t>
                        </p>

                        <p>Versandart: ab Werk streng neutral direkt zum Kunden</p>

                        <p>Anlieferzeiten: Mo–Fr. 09:00–12:30 Uhr und 13:30–16:00 Uhr</p>

                        <p>Nur Motorwagen mit Hebebühne!</p>

                    </t>

                    <!-- Order Confirmation -->
                    <t t-elif="doc.state == 'sale'">

                        <p>Wie gewünscht, übernehmen wir Lizenzierung und Vollständigkeitserklärung.</p>

                        <t t-if="doc.commitment_date">
                            <p>
                                Liefertermin:
                                <span t-field="doc.commitment_date"
                                      t-options='{"widget":"date","format":"dd.MM.yyyy"}'/>
                            </p>
                        </t>

                        <t t-if="doc.payment_term_id">
                            <p>Zahlungsbedingungen: <span t-field="doc.payment_term_id.name"/>.</p>
                        </t>

                        <t t-if="doc.partner_shipping_id">
                            <p>Versand: <span t-field="doc.partner_shipping_id.name"/>.</p>
                        </t>

                        <p>Die Ware bleibt bis zur vollständigen Bezahlung unser Eigentum.</p>

                        <p>Beanstandungen werden nur innerhalb acht Tagen berücksichtigt. Kleine Abweichungen in Farbe, Gewicht und Stoff berechtigen nicht zu Mängelrügen.</p>

                        <p>Toleranzen bei Gewichtsschwankungen (Papier 8%, Kunststoff 25%), Maßabweichungen von 5% und Mengenabweichungen von 20% allg. können nicht beanstandet werden.</p>

                        <p>Es gelten die „Geschäfts-, Liefer- und Zahlungsbedingungen für die Papier- und Kunststoffindustrie“ in Ihrer jeweils neuesten Fassung.</p>

                    </t>

                    <!-- Common Bank Details -->
                    <div class="erz-bank" style="font-size:11pt;">
                        <t t-set="bank" t-value="doc.company_id.bank_ids[:1]"/>
                        <t t-if="bank">
                            <p class="b">Bankverbindung: <t t-esc="bank.bank_id.name"/></p>
                            <div class="erz-bank-center">IBAN: <t t-esc="bank.acc_number"/></div>
                            <div class="erz-bank-center">BIC: <t t-esc="bank.bank_id.bic or ''"/></div>
                        </t>
                        <t t-else="">
                            <p class="b">Bankverbindung: Erzgebirgssparkasse</p>
                            <div class="erz-bank-center">IBAN: DE37 8705 4000 3612 0096 47</div>
                            <div class="erz-bank-center">BIC: WELADED1STB</div>
                        </t>
                    </div>

                </div>
<!--                &lt;!&ndash; Bank details (mid-page, above the fixed footer) &ndash;&gt;-->
<!--                <div class="erz-bank" style="font-size: 11pt;">-->
<!--                    <t t-set="bank" t-value="doc.company_id.bank_ids[:1]"/>-->
<!--                    <t t-if="bank">-->
<!--                        <p class="b">Bankverbindung:&#160;&#160;<t t-esc="bank.bank_id.name"/></p>-->
<!--                        <div class="erz-bank-center">IBAN: <t t-esc="bank.acc_number"/></div>-->
<!--                        <div class="erz-bank-center">BIC: <t t-esc="bank.bank_id.bic or ''"/></div>-->
<!--                    </t>-->
<!--                    <t t-else="">-->
<!--                        <p class="b">Bankverbindung:&#160;&#160;Erzgebirgssparkasse</p>-->
<!--                        <div class="erz-bank-center">IBAN: DE37 8705 4000 3612 0096 47</div>-->
<!--                        <div class="erz-bank-center">BIC: WELADED1STB</div>-->
<!--                    </t>-->
<!--                </div>-->

            </div>
        </t><!-- end t-call layout -->

    </t><!-- end t-foreach -->
</t>
</template>

