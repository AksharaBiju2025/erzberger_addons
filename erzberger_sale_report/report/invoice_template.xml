<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="report_invoice_document_custom">
<t t-call="web.html_container">
    <t t-foreach="docs" t-as="doc">

        <t t-set="o" t-value="doc"/>
        <t t-set="company" t-value="doc.company_id.sudo()"/>
        <t t-call="erzberger_sale_report.report_erz_external_layouts">

            <div style="font-family: Arial, sans-serif; font-size: 9pt; color: #222;">

                    <style>
                    .erz-title {
                        font-size:20pt;
                        font-weight:bold;
                        text-decoration:underline;
                        margin-bottom:2mm;
                    }

                    .erz-ref {
                        font-size:11pt;
                        line-height:1.6;
                    }

                    .meta-lbl,
                    .meta-val {
                        font-size:11pt;
                    }

                    .otbl thead th {
                        font-size:11pt;
                        font-weight:bold;
                        padding:2mm;
                    }

                    .otbl tbody td {
                        font-size:11pt;
                        padding:2mm;
                        vertical-align:top;
                    }

                    .sub {
                        font-size:10pt;
                    }

                    .delivery {
                        font-size:11pt;
                    }

                    .tot-inner td {
                        font-size:11pt;
                    }

                    .tot-grand td {
                        font-size:12pt;
                        font-weight:bold;
                    }

                    .erz-terms {
                        font-size:11pt;
                        line-height:1.6;
                    }

                    .erz-bank {
                        font-size:11pt;
                    }

                    .info-tbl th,
                    .info-tbl td {
                        font-size:11pt;
                    }

                    .info-head th,
                    .info-data td,
                    .line-head th {
                        font-size:11pt;
                    }

                    p {
                        font-size:11pt;
                        margin:0 0 2mm 0;
                    }
                </style>
                 <!-- <div style="font-size:11pt; line-height:1.65; margin:3mm 0;">
                    <t t-if="doc.partner_id.parent_id">
                        <div><t t-esc="doc.partner_id.parent_id.name"/></div>
                    </t>
                    <div t-field="doc.partner_id"
                         t-options='{"widget":"contact","fields":["name","address"],"no_marker":True}'/>
                </div> -->
                <table width="100%" style="border:hidden;">
                        <tr>
                            <td width="50%" style="border:hidden;">
                            <t t-if="doc.partner_id.parent_id">
                            <div><t t-esc="doc.partner_id.parent_id.name"/></div>
                        </t>
                        <div t-field="doc.partner_id" t-options="{&quot;widget&quot;:&quot;contact&quot;,&quot;fields&quot;:[&quot;name&quot;,&quot;address&quot;],&quot;no_marker&quot;:True}"/>
                        </td>
                        <td width="50%" style="padding-left:220px;border:hidden;">
                            <img src="/erzberger_sale_report/static/src/img/img_1.png"
                                 style="width:150px;"/>
                
                            
                        </td>
                        </tr>
                    </table>

                <table style="width:100%; border-collapse:collapse; margin-top:2mm; border:1px solid white;">
                    <tr>
                        <td style="width:58%; vertical-align:top; padding-right:6mm; border:1px solid white;">
                            <div class="erz-title">RECHNUNG</div>
                        </td>
                        <td style="width:42%; vertical-align:top; border:1px solid white;">
                            <table style="border:1px solid white;">
                                <tr style="border:1px solid white;">
                                    <td class="meta-lbl" style="border:1px solid white;">RE-Nr.:</td>
                                    <td class="meta-val b" style="border:1px solid white;"><span t-field="doc.name"/></td>
                                </tr>
                                <tr style="border:1px solid white;">
                                    <td class="meta-lbl" style="border:1px solid white;">Datum:</td>
                                    <td class="meta-val" style="border:1px solid white;">
                                        <span t-field="doc.invoice_date" t-options='{"widget":"date","format":"dd.MM.yyyy"}'/>
                                    </td>
                                </tr>
                                <t t-if="doc.company_id.company_registry">
                                    <tr style="border:1px solid white;">
                                        <td class="meta-lbl" style="border:1px solid white;">St.-Nr.:</td>
                                        <td class="meta-val" style="border:1px solid white;"><t t-esc="doc.company_id.company_registry"/></td>
                                    </tr>
                                </t>
                                <t t-if="doc.company_id.vat">
                                    <tr style="border:1px solid white;">
                                        <td class="meta-lbl" style="border:1px solid white;">Ust.-IdNr.:</td>
                                        <td class="meta-val" style="border:1px solid white;"><span t-field="doc.company_id.vat"/></td>
                                    </tr>
                                </t>
                            </table>
                        </td>
                    </tr>
                </table>

                <!-- <div style="font-size:11pt; line-height:1.65; margin:3mm 0;">
                    <t t-if="doc.partner_id.parent_id">
                        <div><t t-esc="doc.partner_id.parent_id.name"/></div>
                    </t>
                    <div t-field="doc.partner_id"
                         t-options='{"widget":"contact","fields":["name","address"],"no_marker":True}'/>
                </div> -->

