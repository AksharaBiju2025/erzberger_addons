                    </tr>

                </table> -->

                <table class="otbl">

                    <tr class="info-head">
                        <th style="width:22%; text-align:left;padding:4px;"><b>Auftragsnr.</b></th>
                        <th style="width:33%; text-align:left;padding:4px;"><b>Lieferdatum</b></th>
                        <th style="width:22%; text-align:left;padding:4px;"><b>Versandart</b></th>
                        <th style="width:23%; text-align:left;padding:4px;"><b>Lieferbed.</b></th>
                    </tr>

                    <tr class="info-data">
                        <td style="text-align:left;padding:4px;"><span t-field="doc.invoice_origin"/></td>
                        <td style="text-align:left;padding:4px;">Rechnungsdatum = Lieferdatum</td>
                        <td style="text-align:left;padding:4px;">per Spedition</td>
                        <td style="text-align:left;padding:4px;">frei Haus</td>
                    </tr>

                    <tr class="line-head">
                        <th style="text-align:left;padding:4px;"><b>Menge</b><br/><span class="sub">kg/Stück</span></th>
                        <th style="text-align:left;padding:4px;"><b>Bezeichnung</b></th>
                        <th style="text-align:center;" class="tr">
                            <b>Preis/Einheit</b><br/>
                            <span class="sub">per kg/1.000 Stück</span>
                        </th>
                        <th style="text-align:center;" class="tr"><b>Betrag</b></th>
                    </tr>

                    <t t-foreach="doc.invoice_line_ids" t-as="line">
                        <t t-if="line.display_type == 'line_section'">
                            <tr><td colspan="4" class="b" style="font-size:11pt; padding-top:3mm;"><span t-field="line.name"/></td></tr>
                        </t>
                        <t t-elif="line.display_type == 'line_note'">
                            <tr><td colspan="4" style="font-style:italic; font-size:8pt;"><span t-field="line.name"/></td></tr>
                        </t>
                        <t t-else="">
                            <tr>
                                <td class="tl">
                                    <span t-field="line.quantity" t-options="{&quot;widget&quot;:&quot;float&quot;,&quot;decimal_precision&quot;:&quot;Product Unit of Measure&quot;}"/>
                                </td>
                                <td><span t-field="line.name"/></td>
                                <td class="tr">
                                    <t t-if="line.price_unit != 0">
                                        <span t-field="line.price_unit" t-options="{&quot;widget&quot;:&quot;monetary&quot;,&quot;display_currency&quot;:doc.currency_id}"/>
                                    </t><t t-else="">–</t>
                                </td>
                                <td class="tr">
                                    <t t-if="line.price_subtotal != 0">
                                        <span t-field="line.price_subtotal" t-options="{&quot;widget&quot;:&quot;monetary&quot;,&quot;display_currency&quot;:doc.currency_id}"/>
                                    </t><t t-else="">–</t>
                                </td>
                            </tr>
                        </t>
                    </t>
                <t t-set="tax_totals" t-value="doc.tax_totals"/>

                    <tr class="totals-row">

                        <!-- blank area -->
                        <td/>

                        <!-- ONE CELL -->
                        <td style="vertical-align:top;">

                            <t t-foreach="tax_totals['subtotals']" t-as="subtotal">

                                <div>Warenwert</div>

                                <t t-foreach="subtotal['tax_groups']" t-as="tax_group">
                                    <div>
                                        zzgl.
                                        <span t-out="tax_group['group_name']"/>
                                    </div>
                                </t>

                            </t>

                            <div style="font-weight:bold;">
                                Rechnungsbetrag
                            </div>

                        </td>

                        <!-- blank column -->
                        <td/>

                        <!-- ONE CELL -->
                        <td class="tr" style="vertical-align:top;">

                            <t t-foreach="tax_totals['subtotals']" t-as="subtotal">

                                <div>
                                    <span t-out="subtotal['base_amount_currency']" t-options="{&quot;widget&quot;:&quot;monetary&quot;,&quot;display_currency&quot;:doc.currency_id}"/>
                                </div>

                                <t t-foreach="subtotal['tax_groups']" t-as="tax_group">

                                    <div>
                                        <span t-out="tax_group['tax_amount_currency']" t-options="{&quot;widget&quot;:&quot;monetary&quot;,&quot;display_currency&quot;:doc.currency_id}"/>
                                    </div>

                                </t>

                            </t>

                            <div style="font-weight:bold;">
                                <span t-field="doc.amount_total" t-options="{&quot;widget&quot;:&quot;monetary&quot;,&quot;display_currency&quot;:doc.currency_id}"/>
                            </div>

                        </td>

                    </tr>

                </table>

                

                <div class="erz-terms">
                    <t t-if="doc.narration">
                        <span t-field="doc.narration"/>
                    </t>
                    <t t-else="">
                        <t t-if="doc.invoice_payment_term_id and doc.invoice_payment_term_id.early_discount">
                            <p>
                                Zahlung innerhalb von <t t-esc="doc.invoice_payment_term_id.discount_days"/> Tagen
                                mit <t t-esc="doc.invoice_payment_term_id.discount_percentage"/>% Skonto bis
                                <span t-esc="(doc.invoice_date + relativedelta(days=doc.invoice_payment_term_id.discount_days)).strftime('%d.%m.%Y')"/>
                                - (Skonto
                                <span t-esc="'%.2f' % (doc.amount_total * doc.invoice_payment_term_id.discount_percentage / 100)"/>
                                <t t-esc="doc.currency_id.symbol"/>)
                                <br/>
                                oder <t t-esc="doc.invoice_payment_term_id.line_ids[-1].nb_days if doc.invoice_payment_term_id.line_ids else ''"/>
                                Tage netto bis
                                <span t-field="doc.invoice_date_due" t-options='{"widget":"date","format":"dd.MM.yyyy"}'/>
                            </p>
                        </t>
                        <t t-elif="doc.invoice_payment_term_id">
                            <p>Zahlungsbedingungen: <span t-field="doc.invoice_payment_term_id.name"/>.</p>
                        </t>
                        <div class="erz-bank">
                            <t t-set="bank" t-value="doc.company_id.bank_ids[:1]"/>
                            <t t-if="bank">
                                <p class="b">Bankverbindung:&#160;&#160;<t t-esc="bank.bank_id.name"/></p>
                                <div class="erz-bank-center">IBAN: <t t-esc="bank.acc_number"/></div>
                                <div class="erz-bank-center">BIC: <t t-esc="bank.bank_id.bic or ''"/></div>
                            </t>
                            <t t-else="">
                                <p class="b">Bankverbindung:&#160;&#160;Erzgebirgssparkasse</p>
                                <div class="erz-bank-center">IBAN: DE37 8705 4000 3612 0096 47</div>
                                <div class="erz-bank-center">BIC: WELADED1STB</div>
                            </t>
                        </div>
                        <p>Die Ware bleibt bis zur vollständigen Bezahlung unser Eigentum.</p>
                        <p>Sind keine Entsorgungsgebühren aufgeführt, gehen wir davon aus, dass die Service-Verpackungen
                           Ihrerseits nach dem neuen Verpackungsgesetz bei einem dualen System lizensiert und die
                           Mengen beim Verpackungsregister (LUCID) gemeldet werden.</p>
                    </t>
                </div>



            </div>
        </t>

    </t>
</t>
</template>

</odoo>