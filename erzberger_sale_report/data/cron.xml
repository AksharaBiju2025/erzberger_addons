<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ir_cron_quotation_follow_up_reminder" model="ir.cron">
        <field name="name">Quotation Follow-up Reminder</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="state">code</field>
        <field name="code">model._cron_quotation_followup()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_reorder_remainder" model="ir.cron">
        <field name="name">Reorder Reminder</field>
        <field name="model_id" ref="sale.model_sale_order_line"/>
        <field name="state">code</field>
        <field name="code">model._cron_reorder_followup()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_update_qty" model="ir.cron">
        <field name="name">update qty</field>
        <field name="model_id" ref="stock.model_stock_quant"/>
        <field name="state">code</field>
        <field name="code">model.cron_set_company_stock_zero()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

</odoo>