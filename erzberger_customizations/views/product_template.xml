<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_view_inherit_manufacturer" model="ir.ui.view">
        <field name="name">product.template.form.inherit.manufacturer</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">

            <!-- Add a new group inside the Inventory tab -->
            <xpath expr="//page[@name='inventory']/group" position="inside">
                <group string="Herstellung">
                    <field name="hersteller"/>
                    <field name="referenz_hersteller"/>
                </group>
            </xpath>

        </field>
    </record>

</odoo>