<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <record id="view_order_form_job_reference" model="ir.ui.view">
        <field name="name">sale.order.form.job.reference</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='client_order_ref']" position="after">
                <field name="job_reference"/>
            </xpath>

        </field>
    </record>

    <record id="view_quotation_tree_job_reference" model="ir.ui.view">
        <field name="name">sale.order.tree.job.reference</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_tree"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="job_reference"/>
            </xpath>

        </field>
    </record>




</odoo>
